---
import { ExternalLink } from '@lucide/astro';

type HeadingProps = {
  title: string;
  url: string;
  size: 'base' | 'sm';
}

const { title, url, size = 'base' } = Astro.props;
---
<div class="flex items-center gap-1 mt-4">
  {size === 'base' && (<h2 class="font-heading text-lg md:text-xl xl:text-2xl text-grey-800 font-medium">
    {title}
  </h2>)}
  {size === 'sm' && (<h3 class="font-heading text-grey-800 font-medium">
    {title}
  </h3>)}
  {url !== undefined && (
    <a href={url} target="_blank" class="transition-colors duration-150 text-primary hover:text-primary-dark">
      <span class="sr-only">See the official documentation page</span>
      <ExternalLink width="16" />
    </a>
  )}
</div>