---
import Code from '../components/code.astro';
import "../styles/global.css";
import { Heart } from '@lucide/astro';

type BaseLayoutProps = {
  theme: 'teal' | 'blue' | 'orange';
}

const { theme = 'blue', subtitle } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Yago's Cheat Sheets {subtitle && `- ${subtitle}`}</title>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code&family=Fira+Sans:wght@600&family=Inter:wght@300..600&display=swap" rel="stylesheet">
  </head>
  <body class="px-4" data-theme={theme}>
    <slot />

    <footer class="text-sm flex items-center gap-1 justify-center py-4 mt-4">
      Made with <Heart size="1em" class="text-primary-light" /> by <a href="https://yago.io" target="_blank">Yago</a> on <a href="https://github.com/yago/" target="_blank">Github</a>
    </footer>
  </body>
</html>
