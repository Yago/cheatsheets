---
import BaseLayout from '../layouts/base.astro';
import Code from '../components/code.astro';
import Heading from '../components/heading.astro';
import Separator from '../components/separator.astro';
import Content from '../components/content.astro';
---
<BaseLayout theme="teal" subtitle="Cypress">
  <header class="mt-4">
    <h1 class="flex items-center justify-center text-2xl md:text-4xl font-heading font-medium text-center bg-clip-text text-transparent bg-linear-to-r from-primary to-primary-dark">
      <img src="/images/cypress.svg" alt="Cypress logo" class="w-8 md:w-12" />
      <span class="pl-2 md:pl-4">Cypress Cheat Sheet</span>
    </h1>
  </header>

  <div class="grid md:grid-cols-2 gap-6 mt-8 text-center -mb-4 max-md:hidden">
    <p>Basics 👇</p>
    <p>Advanced 👇</p>
  </div>

  <Separator />

  <div class="grid md:grid-cols-2 gap-6">
    <div>
      <Heading title="Setup" url="https://docs.cypress.io/app/get-started/install-cypress" />

      <Code lang="bash" code={`bun add --dev cypress`} />

      <Content>
        <p>Equivalent: <code>npm install --save-dev cypress</code></p>
      </Content>

      <Code lang="json" code={`{
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run"
  },
  "devDependencies": {
    "cypress": "^15"
  }
}`} />

      <Code lang="bash" code={`bun run cypress:open   # interactive runner
bun run cypress:run    # headless CI`} />

      <Code lang="ts" code={`import { defineConfig } from 'cypress';

export default defineConfig({
  e2e: {
    baseUrl: 'http://localhost:3000',
    setupNodeEvents(on, config) {},
  },
});`} />

      <Separator />

      <Heading title="Test structure" url="https://docs.cypress.io/app/core-concepts/writing-and-organizing-tests" />

      <Code code={`describe('Dashboard', () => {
  context('when logged in', () => {
    it('shows the welcome message', () => {
      // ...
    });
  });
});`} />

      <Separator />

      <Heading title="Hooks" url="https://docs.cypress.io/app/core-concepts/writing-and-organizing-tests#Hooks" />

      <Code code={`before(() => { /* once per describe */ });
beforeEach(() => { cy.viewport(1536, 960); });
afterEach(() => { /* cleanup */ });
after(() => { /* once per describe */ });`} />

      <Separator />

      <Heading title="Navigation" url="https://docs.cypress.io/api/commands/visit" />

      <Code code={`cy.visit('/');              // relative to baseUrl
cy.visit('/login', { qs: { next: '/' } });
cy.go('back');
cy.reload();
cy.url().should('include', '/dashboard');`} />

      <Heading title="Viewport" url="https://docs.cypress.io/api/commands/viewport" size="sm" />

      <Code code={`cy.viewport(1536, 960);
cy.viewport('iphone-x');`} />

      <Separator />

      <Heading title="Queries" url="https://docs.cypress.io/app/core-concepts/best-practices#Selecting-Elements" />

      <Content>
        <p>Prefer stable selectors: <code>data-test</code> and <code>data-testid</code> (not <code>data-cy</code>).</p>
      </Content>

      <Code code={`cy.get('[data-testid=submit]');
cy.contains('Sign in');
cy.get('[data-test=form]').find('[data-testid=email]');
cy.get('[data-testid=modal]').within(() => {
  cy.get('[data-testid=confirm]').click();
});`} />

      <Separator />

      <Heading title="Actions" url="https://docs.cypress.io/app/core-concepts/interacting-with-elements" />

      <Code code={`cy.get('[data-testid=submit]').click();
cy.get('[data-testid=email]').type('user@example.com');
cy.get('[data-testid=email]').clear();
cy.get('[data-testid=terms]').check();
cy.get('[data-testid=country]').select('Switzerland');
cy.get('[data-testid=search]').focus();`} />

      <Separator />

      <Heading title="Assertions" url="https://docs.cypress.io/app/references/assertions" />

      <Code code={`cy.get('[data-testid=banner]').should('exist');
cy.get('[data-testid=banner]').should('be.visible');
cy.get('[data-testid=title]').should('have.text', 'Home');
cy.get('[data-testid=email]').should('have.value', 'user@example.com');
cy.get('[data-testid=list]').should('contain', 'Item 1');
cy.get('[data-testid=submit]').should('be.disabled');
cy.get('[data-testid=link]').should('have.attr', 'href', '/about');
cy.get('[data-testid=card]').should('have.class', 'active');
cy.get('[data-testid=row]').should('have.length', 3);

// chain assertions
cy.get('[data-testid=link]')
  .should('be.visible')
  .and('have.attr', 'href', '/home');`} />
    </div>

    <div>
      <Heading title="Network" url="https://docs.cypress.io/api/commands/intercept" />

      <Code code={`cy.intercept('GET', '/api/users', {
  statusCode: 200,
  body: [{ id: 1, name: 'Ada' }],
}).as('getUsers');

cy.visit('/users');
cy.wait('@getUsers');
cy.get('[data-testid=user-row]').should('have.length', 1);`} />

      <Heading title="Stub with fixture" url="https://docs.cypress.io/api/commands/fixture" size="sm" />

      <Code code={`cy.intercept('GET', '/api/users', { fixture: 'users.json' });
cy.fixture('users.json').then((users) => {
  expect(users).to.have.length(2);
});`} />

      <Separator />

      <Heading title="API testing" url="https://docs.cypress.io/api/commands/request" />

      <Code code={`cy.request('GET', '/api/health').its('status').should('eq', 200);

cy.request({
  method: 'POST',
  url: '/api/login',
  body: { email: 'user@example.com', password: 'secret' },
}).then((res) => {
  expect(res.status).to.eq(200);
});`} />

      <Separator />

      <Heading title="Session" url="https://docs.cypress.io/api/commands/session" />

      <Code code={`cy.session('logged-in-user', () => {
  cy.request('POST', '/api/login', {
    email: 'user@example.com',
    password: 'secret',
  });
}, {
  validate() {
    cy.request('/api/me').its('status').should('eq', 200);
  },
});

cy.visit('/dashboard');`} />

      <Separator />

      <Heading title="Custom commands" url="https://docs.cypress.io/api/cypress-api/custom-commands" />

      <Code code={`// cypress/support/e2e.ts
Cypress.Commands.add('login', (email: string, password: string) => {
  cy.session([email, password], () => {
    cy.request('POST', '/api/login', { email, password });
  });
});

declare global {
  namespace Cypress {
    interface Chainable {
      login(email: string, password: string): Chainable<void>;
    }
  }
}

// in a spec
cy.login('user@example.com', 'secret');
cy.visit('/dashboard');`} />

      <Separator />

      <Heading title="Reliability" url="https://docs.cypress.io/app/core-concepts/best-practices" />

      <Content>
        <p>Wait on network aliases, not arbitrary delays. Use <code>data-test</code> / <code>data-testid</code> selectors. Avoid testing implementation details.</p>
      </Content>

      <Code code={`// prefer
cy.wait('@getUsers');

// avoid
cy.wait(5000);

cy.get('[data-testid=submit]', { timeout: 10000 }).click();
cy.get('[data-testid=hidden-menu]').click({ force: true }); // last resort`} />
    </div>
  </div>

</BaseLayout>
